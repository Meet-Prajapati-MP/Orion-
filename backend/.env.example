# ─────────────────────────────────────────────────────────────
# Orion Backend — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── OPTION A: Groq (FREE — recommended for getting started) ──
# Enables /generate/stream (real-time word-by-word streaming output)
# Get your free key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_key_here

# ── OPTION B: OpenAI + Serper (full CrewAI multi-agent pipeline) ──
# Runs the full 5-agent research pipeline — more powerful but paid
# OpenAI: https://platform.openai.com/api-keys
# Serper: https://serper.dev  (2,500 free web searches/month)
OPENAI_API_KEY=sk-your-key-here
SERPER_API_KEY=your-serper-key-here

# ── Optional settings ──────────────────────────────────────
RATE_LIMIT_RPM=10
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
